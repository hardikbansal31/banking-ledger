# =============================================================================
# Banking Ledger — Local Dev Environment
# This is YOUR ACTUAL .env file — never commit this to git.
# Add .env to your .gitignore immediately.
# =============================================================================

# ─── MySQL (your local Ubuntu MySQL 8.4) ─────────────────────────────────────
# Using your existing dashuser — no need to create ledger_app
MYSQL_HOST=localhost
MYSQL_HOST_PORT=3306
MYSQL_DATABASE=banking_ledger
MYSQL_USER=dashuser
MYSQL_PASSWORD=mypassword

# ─── Redis (Docker container) ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_HOST_PORT=6380
REDIS_PASSWORD=RedisDevPass@99

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Mock secret — fine for local dev only
# Generate a real one for any shared env: openssl rand -base64 64
JWT_SECRET=bW9ja0RldlNlY3JldEtleUZvckxvY2FsRGV2ZWxvcG1lbnRPbmx5MjAyNUJhbmtpbmdMZWRnZXI=
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Exchange Rate API ────────────────────────────────────────────────────────
# Not needed until Phase 5 — mock value is fine for now
EXCHANGE_RATE_API_KEY=mock-exchange-rate-key-replace-in-phase-5
EXCHANGE_RATE_BASE_URL=https://v6.exchangerate-api.com/v6

# ─── Actuator ─────────────────────────────────────────────────────────────────
ACTUATOR_USERNAME=actuator_admin
ACTUATOR_PASSWORD=ActuatorDev@55

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENVIRONMENT=development
LOG_LEVEL=DEBUG